{
  "name": "server",
  "version": "0.0.0",
  "description": "server of auth project",
  "main": "dist/main.js",
  "exports": {
    "./*": "./src/**/*.ts"
  },
  "scripts": {
    "build": "ENV=prod tsc -b",
    "db:check": "drizzle-kit check",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:up": "drizzle-kit up",
    "dev": "ENV=dev tsx --watch src/main.ts",
    "migrate": "npm run migrate",
    "start": "ENV=prod node dist/main.js",
    "studio": "drizzle-kit studio"
  },
  "keywords": [
    "server",
    "auth"
  ],
  "author": "Rahul Roy",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "policy": "workspace:*",
    "schema": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "ts-config": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
