{
  "extends": "ts-config/base",
  "compilerOptions": {
    //   "useDefineForClassFields": true,
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,

    "moduleResolution": "nodenext",
    "moduleDetection": "force"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
